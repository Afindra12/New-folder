        async function generateItinerary() {
            const durasi = parseInt(document.getElementById("durasiSelect").value) * 60;
            const filtered = getFilteredDestinations();
            const routeInfos = new Map();
            for (const d of filtered) { const r = await getRouteInfo(d); if (r) routeInfos.set(d.id, r); }
            const sorted = [...filtered].sort((a,b) => computeScore(b, routeInfos.get(b.id)) - computeScore(a, routeInfos.get(a.id)));
            let total = 0, itinerary = [];
            for (const d of sorted) {
                const travel = routeInfos.get(d.id)?.time || 999;
                if (total + travel + d.estimasiWaktu <= durasi) { itinerary.push(d); total += travel + d.estimasiWaktu; }
            }
            const icon = { Geodiversity:'🗻', Biodiversity:'🌿', 'Cultural Diversity':'🏛️' };
            alert(itinerary.length ? `🗺️ ITINERARY (${itinerary.length} destinasi):\n${itinerary.map((d,i)=>`${i+1}. ${icon[d.classification]} ${d.name}`).join('\n')}\nTotal: ${Math.floor(total/60)} jam ${total%60} mnt` : "Tidak ada destinasi yang muat.");
