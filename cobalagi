<!doctype html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WebGIS Geopark Kebumen | Network Analysis Jalan Nyata</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        :root {
            --bg: #f4f7f2;
            --card: #ffffff;
            --primary: #1a472a;
            --primary-dark: #0d2818;
            --accent: #e8b86b;
            --accent-soft: #fcf3e0;
            --text: #1f2937;
            --muted: #6b7280;
            --line: #d1ddd6;
            --shadow: 0 10px 30px rgba(20, 50, 40, 0.08);
            --radius: 20px;
        }
        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: "Segoe UI", "Roboto", Arial, sans-serif;
            background: radial-gradient(circle at top right, rgba(232, 184, 107, 0.12), transparent 25%), linear-gradient(145deg, #f8fbf9 0%, #eef3ef 100%);
        }
        .container { width: min(1320px, calc(100% - 32px)); margin: 0 auto; }
        .hero { padding: 28px 0 16px; }
        .hero-card {
            background: linear-gradient(145deg, rgba(26, 71, 42, 0.98), rgba(13, 40, 24, 0.95));
            color: white;
            border-radius: 28px;
            padding: 32px 30px;
            box-shadow: var(--shadow);
            position: relative;
            overflow: hidden;
        }
        .hero-card::after {
            content: "";
            position: absolute;
            right: -90px;
            top: -90px;
            width: 280px;
            height: 280px;
            background: rgba(232, 184, 107, 0.18);
            border-radius: 50%;
        }
        .badge {
            display: inline-flex;
            gap: 8px;
            background: rgba(255,255,255,0.18);
            border: 1px solid rgba(255,255,255,0.28);
            padding: 8px 14px;
            border-radius: 999px;
            font-size: 13px;
            margin-bottom: 16px;
        }
        h1 { margin: 0 0 10px; font-size: clamp(28px, 5vw, 42px); line-height: 1.15; font-weight: 600; }
        .subtitle { margin: 0 0 12px; max-width: 820px; line-height: 1.6; color: rgba(255,255,255,0.9); font-size: 14px; }
        .hero-grid { display: grid; grid-template-columns: 1.3fr 0.7fr; gap: 18px; align-items: end; }
        .hero-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-top: 24px; }
        .stat { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2); border-radius: 18px; padding: 16px 18px; }
        .stat h3 { margin: 0 0 4px; font-size: 28px; font-weight: 600; }
        .stat p { margin: 0; font-size: 12px; opacity: 0.85; }
        .mini-panel { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.22); border-radius: 20px; padding: 20px; }
        .mini-panel h4 { margin: 0 0 14px; font-size: 16px; }
        .mini-panel ul { margin: 0; padding-left: 18px; line-height: 1.7; }
        .dashboard { display: grid; grid-template-columns: 360px 1fr; gap: 18px; margin: 18px 0 24px; }
        .card { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); box-shadow: var(--shadow); }
        .sidebar { padding: 20px; position: sticky; top: 16px; height: fit-content; max-height: calc(100vh - 100px); overflow-y: auto; }
        .sidebar h2, .content-card h2 { margin: 0 0 16px; font-size: 20px; font-weight: 600; }
        .helper { color: var(--muted); font-size: 13px; line-height: 1.65; margin-top: -4px; margin-bottom: 16px; }
        .control-label { display: block; font-size: 13px; font-weight: 600; margin: 16px 0 8px; color: var(--primary-dark); }
        select, .search-input { width: 100%; border: 1px solid var(--line); border-radius: 14px; padding: 10px 12px; font-size: 14px; outline: none; background: white; }
        .chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
        .chip { border: none; background: #f0f4f1; color: var(--primary-dark); padding: 8px 12px; border-radius: 999px; cursor: pointer; font-size: 13px; transition: all 0.2s; font-weight: 500; }
        .chip.active, .chip:hover { background: var(--primary); color: white; }
        .btn-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-top: 14px; }
        .btn { border: none; border-radius: 14px; padding: 10px 12px; cursor: pointer; font-weight: 600; font-size: 13px; transition: all 0.2s; }
        .btn-primary { background: var(--primary); color: white; }
        .btn-primary:hover { background: var(--primary-dark); }
        .btn-secondary { background: var(--accent-soft); color: #8a5718; }
        .legend { margin-top: 18px; padding: 14px 16px; background: #fafdfb; border: 1px dashed #c8d9d0; border-radius: 16px; }
        .legend-item { display: flex; align-items: center; gap: 10px; font-size: 13px; margin-bottom: 8px; }
        .legend-dot { width: 14px; height: 14px; border-radius: 50%; display: inline-block; }
        .content { display: grid; gap: 18px; }
        .content-card { padding: 20px; }
        #map { width: 100%; height: 520px; border-radius: 18px; overflow: hidden; border: 1px solid var(--line); }
        .top-info { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 16px; }
        .info-box { background: #f8fbfa; border: 1px solid var(--line); border-radius: 16px; padding: 12px; }
        .info-box span { display: block; color: var(--muted); font-size: 12px; margin-bottom: 4px; }
        .info-box strong { font-size: 16px; color: var(--primary-dark); }
        .analysis-panel { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 18px; }
        .route-list { display: grid; gap: 10px; max-height: 400px; overflow-y: auto; }
        .route-item { border: 1px solid var(--line); border-radius: 16px; padding: 12px; background: #fff; cursor: pointer; transition: transform 0.2s, box-shadow 0.2s; }
        .route-item:hover, .route-item.active { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(26,59,48,0.06); border-color: #b9d5cb; background: #f9fffc; }
        .route-item h4 { margin: 0 0 5px; font-size: 15px; }
        .route-meta { display: flex; flex-wrap: wrap; gap: 6px; font-size: 12px; color: var(--muted); }
        .pill { display: inline-block; padding: 4px 8px; border-radius: 999px; font-size: 11px; font-weight: 600; }
        .pill-geo { background: #2a9d8f; color: white; }
        .pill-bio { background: #52b788; color: white; }
        .pill-cultural { background: #e9b35f; color: #5a3e1b; }
        .highlight-box { background: linear-gradient(180deg, #fcfffd 0%, #f4fbf7 100%); border: 1px solid var(--line); border-radius: 18px; padding: 16px; max-height: 450px; overflow-y: auto; }
        .highlight-box h3 { margin-top: 0; font-size: 18px; }
        .highlight-box ul { margin: 10px 0 0; padding-left: 18px; line-height: 1.7; color: #475467; }
        table { width: 100%; border-collapse: collapse; font-size: 12px; }
        thead { background: #f5f9f7; }
        th, td { padding: 8px 6px; text-align: left; border-bottom: 1px solid #e6efea; }
        tr:hover td { background: #fbfdfc; }
        .footer { padding: 0 0 28px; color: var(--muted); font-size: 13px; text-align: center; }
        .note { margin-top: 12px; padding: 10px 12px; background: #fff7ef; border: 1px solid #f8d7b4; border-radius: 14px; color: #8a5718; font-size: 12px; }
        .rekomendasi-geo { margin-top: 14px; padding-top: 8px; border-top: 1px dashed #d9e2dc; }
        .btn-itinerary { background: #1a472a; color: white; border: none; border-radius: 40px; padding: 12px 18px; font-weight: 600; width: 100%; cursor: pointer; margin-top: 12px; }
        .btn-itinerary:hover { background: #0d2818; }
        .score-badge { background: #e8b86b; color: #2c3e2b; padding: 2px 8px; border-radius: 12px; font-size: 10px; font-weight: bold; }
        .user-location-btn { background: #e8b86b; color: #1a472a; border: none; border-radius: 14px; padding: 10px; font-weight: 600; margin-top: 8px; cursor: pointer; width: 100%; }
        .user-location-btn:hover { background: #d4a04a; }
        .vehicle-select { background: #f0f4f1; border-radius: 14px; padding: 10px; margin-top: 10px; }
        .vehicle-option { display: flex; align-items: center; gap: 12px; padding: 8px; cursor: pointer; border-radius: 12px; transition: background 0.2s; }
        .vehicle-option:hover { background: #e0e8e0; }
        .vehicle-option.active { background: var(--primary); color: white; }
        .vehicle-option.active .vehicle-label { color: white; }
        .vehicle-icon { font-size: 20px; }
        .vehicle-label { font-weight: 500; }
        .loading { position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(0,0,0,0.8); color: white; padding: 20px 40px; border-radius: 12px; z-index: 9999; display: none; }
        @media (max-width: 1024px) { .hero-grid, .dashboard, .analysis-panel { grid-template-columns: 1fr; } .top-info { grid-template-columns: repeat(2, 1fr); } .sidebar { position: relative; top: 0; } }
        @media (max-width: 640px) { .container { width: min(100% - 20px, 100%); } .hero-stats, .top-info, .btn-row { grid-template-columns: 1fr; } #map { height: 380px; } }
    </style>
</head>
<body>
    <div class="container hero">
        <div class="hero-card">
            <div class="hero-grid">
                <div>
                    <div class="badge">🏔️ Geopark Karangsambung–Karangbolong · Network Analysis Jalan Nyata · Shortest Path</div>
                    <h1>WebGIS Persebaran Wisata Geopark Kebumen</h1>
                    <p class="subtitle">Sistem perencanaan wisata berbasis analisis jaringan jalan nyata (Shortest Path) dengan rekomendasi rute tercepat berdasarkan klasifikasi jalan dan jenis kendaraan.</p>
                    <div class="hero-stats">
                        <div class="stat"><h3 id="heroTotalWisata">0</h3><p>Total Destinasi</p></div>
                        <div class="stat"><h3 id="heroGeoCount">0</h3><p>Geodiversity</p></div>
                        <div class="stat"><h3 id="heroBioCount">0</h3><p>Biodiversity</p></div>
                        <div class="stat"><h3 id="heroCulturalCount">0</h3><p>Cultural Diversity</p></div>
                    </div>
                </div>
                <div class="mini-panel">
                    <h4>✨ Fitur WebGIS & Network Analysis</h4>
                    <ul>
                        <li><strong>Shortest Path</strong> (rute tercepat via jaringan jalan nyata)</li>
                        <li>Rekomendasi destinasi berdasarkan klasifikasi</li>
                        <li>Itinerary otomatis</li>
                        <li>Filter kategori geopark</li>
                        <li>Filter jenis kendaraan (Mobil/Motor/Pejalan kaki)</li>
                        <li>Analisis rekomendasi kendaraan</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <main class="container dashboard">
        <aside class="card sidebar">
            <h2>🔍 Panel Network Analysis</h2>
            <p class="helper">Analisis rute tercepat berbasis jaringan jalan nyata (GeoJSON)</p>

            <label class="control-label" for="originSelect">📍 Titik Awal (Origin)</label>
            <select id="originSelect">
                <option value="alun">Alun-Alun Kebumen</option>
                <option value="stasiun">Stasiun Kebumen</option>
                <option value="terminal">Terminal Kebumen</option>
                <option value="userLocation">📍 Lokasi Saya (GPS)</option>
            </select>
            <button class="user-location-btn" id="getUserLocationBtn">📍 Gunakan Lokasi Saya</button>

            <label class="control-label">🚗 Jenis Kendaraan</label>
            <div class="vehicle-select" id="vehicleSelect">
                <div class="vehicle-option active" data-vehicle="car"><span class="vehicle-icon">🚗</span><span class="vehicle-label">Mobil / Bus / Truk</span></div>
                <div class="vehicle-option" data-vehicle="motorcycle"><span class="vehicle-icon">🏍️</span><span class="vehicle-label">Motor</span></div>
                <div class="vehicle-option" data-vehicle="pedestrian"><span class="vehicle-icon">🚶</span><span class="vehicle-label">Pejalan Kaki</span></div>
            </div>

            <label class="control-label" for="preferensiSelect">🎯 Preferensi Wisata</label>
            <select id="preferensiSelect">
                <option value="semua">Semua Kategori</option>
                <option value="Geodiversity">🗻 Geodiversity (Geologi)</option>
                <option value="Biodiversity">🌿 Biodiversity (Hayati)</option>
                <option value="Cultural Diversity">🏛️ Cultural Diversity (Budaya)</option>
            </select>

            <label class="control-label" for="durasiSelect">⏱️ Durasi Wisata (jam)</label>
            <select id="durasiSelect">
                <option value="3">3 jam (Setengah hari)</option>
                <option value="5" selected>5 jam (Sehari penuh)</option>
                <option value="8">8 jam (Eksplorasi penuh)</option>
            </select>

            <label class="control-label" for="searchInput">🔎 Cari Destinasi</label>
            <input id="searchInput" class="search-input" type="text" placeholder="Ketik nama destinasi..." />

            <label class="control-label">🏷️ Filter Kategori Geopark</label>
            <div class="chips" id="categoryChips"></div>

            <div class="btn-row">
                <button class="btn btn-primary" id="btnShowAll">Tampilkan Semua</button>
                <button class="btn btn-secondary" id="btnResetView">Reset Peta</button>
            </div>

            <button class="btn-itinerary" id="generateItineraryBtn">🗺️ Generate Itinerary Otomatis</button>

            <div class="legend">
                <div class="legend-item"><span class="legend-dot" style="background: #2a9d8f;"></span> Geodiversity</div>
                <div class="legend-item"><span class="legend-dot" style="background: #52b788;"></span> Biodiversity</div>
                <div class="legend-item"><span class="legend-dot" style="background: #e9b35f;"></span> Cultural Diversity</div>
                <div class="legend-item"><span class="legend-dot" style="background: #3388ff;"></span> Jalan Arteri</div>
                <div class="legend-item"><span class="legend-dot" style="background: #44aaff;"></span> Jalan Kolektor</div>
                <div class="legend-item"><span class="legend-dot" style="background: #66ccff;"></span> Jalan Lokal</div>
                <div class="legend-item"><span class="legend-dot" style="background: #ff6600;"></span> Rute Terpilih</div>
            </div>

            <div class="note">
                <strong>📊 Analisis Aksesibilitas:</strong><br/>
                • <strong>Mudah</strong> = Jarak dari jalan utama &lt; 500m<br/>
                • <strong>Sedang</strong> = Jarak 500m - 1km<br/>
                • <strong>Sulit</strong> = Jarak &gt; 1km
            </div>
        </aside>

        <section class="content">
            <div class="card content-card">
                <h2>🗺️ Peta Interaktif & Rute Network Analysis</h2>
                <div class="top-info">
                    <div class="info-box"><span>Titik Awal</span><strong id="activeOriginName">Alun-Alun Kebumen</strong></div>
                    <div class="info-box"><span>Destinasi Terdekat</span><strong id="nearestName">-</strong></div>
                    <div class="info-box"><span>Waktu Tempuh Tercepat</span><strong id="nearestTime">-</strong></div>
                    <div class="info-box"><span>Destinasi Tersulit Akses</span><strong id="hardestAccess">-</strong></div>
                </div>
                <div id="map"></div>
            </div>

            <div class="analysis-panel">
                <div class="card content-card">
                    <h2>📋 Rekomendasi Rute (Shortest Path)</h2>
                    <p class="helper">Urutan berdasarkan skor preferensi + jarak terdekat. Klik untuk lihat rute tercepat via jaringan jalan.</p>
                    <div id="routeList" class="route-list"></div>
                </div>

                <div class="card content-card">
                    <h2>📍 Detail & Rekomendasi Serupa</h2>
                    <div class="highlight-box" id="detailPanel">
                        <h3>Pilih Destinasi</h3>
                        <p class="helper">Klik marker pada peta atau kartu rekomendasi untuk melihat detail lengkap.</p>
                    </div>
                </div>
            </div>

            <div class="card content-card">
                <h2>📊 Tabel Analisis Aksesibilitas Destinasi</h2>
                <div style="overflow: auto; max-height: 300px;">
                    <table>
                        <thead><tr><th>No</th><th>Nama Destinasi</th><th>Klasifikasi</th><th>Tipe</th><th>Akses</th><th>Jarak ke Jalan</th><th>Waktu</th><th>Edukasi</th><th>Rekom Kendaraan</th></tr></thead>
                        <tbody id="destinationTableBody"></tbody>
                    </table>
                </div>
            </div>
        </section>
    </main>

    <footer class="container footer">
        <p>🌿 WebGIS Geopark Karangsambung-Karangbolong | Berbasis Network Analysis Jalan Nyata | Shortest Path · Dijkstra Algorithm</p>
    </footer>

