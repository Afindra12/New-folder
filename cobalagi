            await refreshUI();
        }));
        
        window.focusDestination = focusDestination;
        
        // LOAD NETWORK
        roadGraph = buildGraphFromGeoJSON(roadGeoJSON);
        isNetworkLoaded = true;
        roadLayer = L.geoJSON(roadGeoJSON, { style: f => ROAD_STYLES[f.properties.klasifikasi] || ROAD_STYLES.lokal }).addTo(map);
        refreshUI();
    </script>
