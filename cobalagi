        function haversineDistance(lat1, lon1, lat2, lon2) {
            const R = 6371;
            const dLat = (lat2 - lat1) * Math.PI / 180;
            const dLon = (lon2 - lon1) * Math.PI / 180;
            const a = Math.sin(dLat/2) * Math.sin(dLat/2) + Math.cos(lat1 * Math.PI/180) * Math.cos(lat2 * Math.PI/180) * Math.sin(dLon/2) * Math.sin(dLon/2);
            const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
            return R * c;
        }
        
        function buildGraphFromGeoJSON(geojson) {
            const nodes = new Map();
            const edges = [];
            let nodeId = 0;
            const getNodeKey = (lat, lng) => `${lat.toFixed(6)},${lng.toFixed(6)}`;
            
            geojson.features.forEach(feature => {
                const geom = feature.geometry;
                const roadType = feature.properties.klasifikasi || 'lokal';
                
                if (geom.type === 'LineString') {
                    const coords = geom.coordinates;
                    const segmentNodes = [];
                    
                    for (let i = 0; i < coords.length; i++) {
                        const lng = coords[i][0];
                        const lat = coords[i][1];
                        const key = getNodeKey(lat, lng);
                        if (!nodes.has(key)) nodes.set(key, { id: nodeId++, lat, lng, key });
                        segmentNodes.push(nodes.get(key));
                    }
                    
                    for (let i = 0; i < segmentNodes.length - 1; i++) {
                        const fromNode = segmentNodes[i];
                        const toNode = segmentNodes[i+1];
                        const distance = haversineDistance(fromNode.lat, fromNode.lng, toNode.lat, toNode.lng);
                        if (distance > 0) {
                            edges.push({
                                from: fromNode.id, to: toNode.id,
                                distance: distance, time: distance / 40 * 60,
                                roadType: roadType, geometry: [fromNode, toNode]
                            });
                        }
                    }
                }
            });
            return { nodes, edges };
        }
        
        function dijkstra(graph, startId, targetId, vehicleType) {
            const distances = new Map();
            const previous = new Map();
            const visited = new Set();
            const pq = [];
            
            graph.nodes.forEach(node => distances.set(node.id, Infinity));
            distances.set(startId, 0);
            pq.push({ id: startId, dist: 0 });
            
            while (pq.length) {
                pq.sort((a,b) => a.dist - b.dist);
                const current = pq.shift();
                if (visited.has(current.id)) continue;
                visited.add(current.id);
                if (current.id === targetId) break;
                
                const outgoing = graph.edges.filter(e => e.from === current.id);
                for (const edge of outgoing) {
                    if (visited.has(edge.to)) continue;
                    if (!VEHICLE_ROAD_ACCESS[vehicleType].includes(edge.roadType)) continue;
                    const newDist = distances.get(current.id) + edge.distance;
                    if (newDist < distances.get(edge.to)) {
                        distances.set(edge.to, newDist);
                        previous.set(edge.to, { nodeId: current.id, edge });
                        pq.push({ id: edge.to, dist: newDist });
                    }
                }
            }
            
            const path = [];
            let curr = targetId;
            while (previous.has(curr)) {
                const prev = previous.get(curr);
                path.unshift(prev.edge);
                curr = prev.nodeId;
            }
            return { path, distance: distances.get(targetId), time: distances.get(targetId) / 40 * 60, found: distances.get(targetId) !== Infinity };
        }
        
        function snapToNearestNode(lat, lng, graph) {
            let minDist = Infinity, nearest = null;
            graph.nodes.forEach(node => {
                const dist = haversineDistance(lat, lng, node.lat, node.lng);
                if (dist < minDist) { minDist = dist; nearest = node; }
            });
            return nearest;
        }
        
        function calculateRoute(originCoords, destCoords, graph, vehicleType) {
            if (!graph.nodes.size) return null;
            const originNode = snapToNearestNode(originCoords[0], originCoords[1], graph);
            const destNode = snapToNearestNode(destCoords[0], destCoords[1], graph);
            if (!originNode || !destNode) return null;
            
            const result = dijkstra(graph, originNode.id, destNode.id, vehicleType);
            if (!result.found) return null;
            
            const coords = [[originCoords[0], originCoords[1]]];
            for (const edge of result.path) {
                coords.push([edge.geometry[0].lat, edge.geometry[0].lng]);
                coords.push([edge.geometry[1].lat, edge.geometry[1].lng]);
            }
            coords.push([destCoords[0], destCoords[1]]);
            
            const unique = [];
            for (const c of coords) {
                if (!unique.length || unique[unique.length-1][0] !== c[0] || unique[unique.length-1][1] !== c[1]) unique.push(c);
            }
            
            let hasSetapak = false;
            for (const edge of result.path) if (edge.roadType === 'setapak') hasSetapak = true;
            
            return {
                coords: unique, distance: result.distance, time: result.time,
                recommendedVehicle: hasSetapak ? 'Motor' : 'Mobil'
            };
        }
        
